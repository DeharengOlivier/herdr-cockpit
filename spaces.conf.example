# herdr-cockpit: the spaces recreated every time WezTerm opens.
#
# Copy this file to "spaces.conf" (not tracked by git) and adapt it.
#     cp spaces.conf.example spaces.conf
#
# Common root of your projects. Optional, but it shortens the paths below and
# the project names displayed in the statistics panel.
PROJECTS_ROOT=~/dev

# Your GitHub username. Optional. If it is filled in, install.sh fetches your
# avatar and displays it in the top right corner of the statistics panel, along
# with your name and a clickable link to your profile. Leave empty for nothing.
# To regenerate it later:  bin/github-badge.py <username>
GITHUB_USER=

# One space per line: the label, a TAB, then the path.
#
#   - The separator must be a real tab, not spaces: both the labels and the
#     paths may contain spaces.
#   - A relative path is resolved from PROJECTS_ROOT.
#   - An absolute path (/... or ~/...) is taken as is.
#   - The order of the lines is the display order in the left column.
#   - A path that does not exist is reported then ignored, never created.
#
# The statistics space "▦ Stats" is added automatically, do not list it here.

client-acme	clients/acme
my-product	products/my-product
dotfiles	~/.dotfiles
